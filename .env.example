# Application settings
LMP_ENV=local
LMP_TIMEZONE=America/New_York
LMP_DEFAULT_ZONE=AEP
LMP_FORECAST_HORIZON=24
LMP_INPUT_SIZE=168

# Training defaults
LMP_FORECASTER_DEFAULT_ZONE=AEP
LMP_FORECASTER_TIMEZONE=America/New_York
LMP_FORECASTER_MLFLOW_TRACKING_URI=sqlite:///mlruns.db
LMP_FORECASTER_ARTIFACT_DIR=artifacts

# PJM API defaults
PJM_API_KEY=
PJM_API_BASE_URL=https://api.pjm.com/api/v1
PJM_DATA_MINER_BASE_URL=https://dataminer2.pjm.com

# Tracking and storage
MLFLOW_TRACKING_URI=file:./mlruns

# Optional local model services
OLLAMA_HOST=http://localhost:11434
